# Copy to .env for local overrides (optional).

# Port the server listens on. Railway sets this automatically in production.
PORT=3000

# Where board JSON files are stored. In production point this at a mounted
# volume so data survives redeploys, e.g. DATA_DIR=/data
DATA_DIR=./data

# Set to "production" on Railway so session cookies are marked Secure.
NODE_ENV=development
